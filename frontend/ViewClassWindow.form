    private void backBtnActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_backBtnActionPerformed
        TrainerRoleWindow a1 = new TrainerRoleWindow();
        setVisible(false);    }//GEN-LAST:event_backBtnActionPerformed

    private void addBtnActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_addBtnActionPerformed
        if (classIDText.getText().equals("") || memberIDText.getText().equals("") || date.getDate()==null) {
            
            JOptionPane.showMessageDialog(null, "Some Feilds are Empty !!");
        } else {
            TrainerRole trainer;
            try {
                trainer = new TrainerRole();
                LocalDate localDate = LocalDate.ofInstant(date.getDate().toInstant(), ZoneId.systemDefault());
                trainer.registerMemberForClass(memberIDText.getText(), classIDText.getText(), localDate);
                trainer.logout();
                TrainerRoleWindow a1 = new TrainerRoleWindow();
                setVisible(false);
            } catch (IOException ex) {
                Logger.getLogger(AddTrainerWindow.class.getName()).log(Level.SEVERE, null, ex);
            }

        }     }//GEN-LAST:event_addBtnActionPerformed

