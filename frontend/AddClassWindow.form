    private void backBtnActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_backBtnActionPerformed
        TrainerRoleWindow a1 = new TrainerRoleWindow();
        setVisible(false);    }//GEN-LAST:event_backBtnActionPerformed

    private void cancelBtnActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_cancelBtnActionPerformed
        if (classIDText.getText().equals("") || memberIDText.getText().equals("")) {
            JOptionPane.showMessageDialog(null, "Some Feilds are Empty !!");
        } else {
            TrainerRole trainer;
            try {
                trainer = new TrainerRole();
                 trainer.cancelRegistration(memberIDText.getText(), classIDText.getText());
                trainer.logout();
                TrainerRoleWindow a1 = new TrainerRoleWindow();
                setVisible(false);
            } catch (IOException ex) {
                Logger.getLogger(AddTrainerWindow.class.getName()).log(Level.SEVERE, null, ex);
            }

        }     }//GEN-LAST:event_cancelBtnActionPerformed

